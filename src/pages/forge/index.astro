---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ForgeGrid from '../../components/ForgeGrid.tsx';
import { getCollection } from 'astro:content';

const forgeEntries = await getCollection('forge');
const programs = forgeEntries.map(e => e.data).sort((a, b) => a.name.localeCompare(b.name));
---

<BaseLayout title="Projekte" description="Open-Source-Programme für die Arztpraxis – kostenlos, lokal, datenschutzkonform" variant="forge">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <!-- Header -->
    <div class="text-center mb-12">
      <h1 class="text-4xl font-bold text-text-primary mb-3">
        Asklaion Projekte
      </h1>
      <p class="text-text-secondary max-w-2xl mx-auto">
        Open-Source-Programme für die Arztpraxis – kostenlos, lokal, datenschutzkonform.
        <br />
        Alle Programme können so genutzt werden, wie sie sind, oder als Basis für eigene Weiterentwicklungen dienen.
      </p>
      <p class="text-xs text-text-muted mt-2">Open Source · MIT Lizenz · 100 % lokal</p>
    </div>

    <ForgeGrid client:load programs={programs} />
  </div>
</BaseLayout>
