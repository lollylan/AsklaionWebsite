---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const forgeEntries = await getCollection('forge');
  return forgeEntries.map(entry => ({
    params: { slug: entry.data.slug },
    props: { program: entry.data },
  }));
}

const { program } = Astro.props;
const base = import.meta.env.BASE_URL;

const BADGE_COLORS: Record<string, string> = {
  GERING: 'bg-badge-gering/20 text-badge-gering',
  MITTEL: 'bg-badge-mittel/20 text-badge-mittel',
  HOCH: 'bg-badge-hoch/20 text-badge-hoch',
  WEBAPP: 'bg-badge-webapp/20 text-badge-webapp',
};
---

<BaseLayout title={program.name} description={program.description} variant="forge">
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <!-- Breadcrumb -->
    <nav class="mb-6 text-sm text-text-muted">
      <a href={`${base}forge`} class="hover:text-forge-accent transition-colors">Projekte</a>
      <span class="mx-2">/</span>
      <span class="text-text-secondary">{program.name}</span>
    </nav>

    <!-- Hero -->
    <div class="mb-8">
      {program.video_url ? (
        <div class="aspect-video rounded-xl overflow-hidden bg-dark-card border border-dark-border mb-6">
          <iframe src={program.video_url} class="w-full h-full" allowfullscreen />
        </div>
      ) : program.screenshot ? (
        <div class="aspect-video rounded-xl overflow-hidden bg-dark-card border border-dark-border mb-6">
          <img src={`${base}${program.screenshot.replace(/^\//, '')}`} alt={program.name} class="w-full h-full object-cover" />
        </div>
      ) : (
        <div class="aspect-video rounded-xl overflow-hidden bg-forge-bg/50 border border-dark-border mb-6 flex items-center justify-center">
          <span class="text-sm font-medium text-text-muted opacity-40 uppercase tracking-wider">{program.category === 'webapp' ? 'Web-App' : 'Desktop'}</span>
        </div>
      )}
    </div>

    <!-- Title + Meta -->
    <div class="flex flex-wrap items-start gap-3 mb-4">
      <h1 class="text-3xl font-bold text-text-primary">{program.name}</h1>
      <span class={`px-3 py-1 text-xs font-bold rounded ${BADGE_COLORS[program.anforderung]}`}>
        {program.anforderung}
      </span>
    </div>

    <!-- Tags -->
    <div class="flex flex-wrap gap-2 mb-6">
      {program.tags.map((tag: string) => (
        <span class="px-2 py-0.5 text-xs font-medium rounded bg-dark-border/50 text-text-muted">{tag}</span>
      ))}
    </div>

    <!-- Description -->
    <div class="bg-dark-card border border-dark-border rounded-xl p-6 mb-8">
      <p class="text-text-secondary leading-relaxed">{program.description}</p>
    </div>

    {/* Hinweis (z.B. Einstellung, Nachfolger) */}
    {program.notice && (
      <div class="bg-badge-mittel/10 border border-badge-mittel/30 rounded-xl p-6 mb-8">
        <p class="text-sm text-text-secondary">
          {program.notice}
          {program.notice_link && (
            <a href={program.notice_link} class="ml-1 font-semibold text-forge-accent hover:text-forge-accent-light transition-colors">
              {program.notice_link_label || 'Mehr erfahren'} &rarr;
            </a>
          )}
        </p>
      </div>
    )}

    <!-- Actions -->
    <div class="flex flex-wrap gap-4 mb-8 bg-dark-card border border-dark-border rounded-xl p-6">
      {/* Programme (install): Release + Repository */}
      {program.category === 'install' && program.release_url && (
        <a
          href={program.release_url}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 px-5 py-2.5 bg-forge-accent hover:bg-forge-accent-light text-forge-bg font-semibold rounded-lg transition-colors"
        >
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4" />
          </svg>
          Release herunterladen
        </a>
      )}
      {/* Demo/App-Link */}
      {program.demo_url && (
        <a
          href={program.demo_url}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 px-5 py-2.5 bg-forge-accent hover:bg-forge-accent-light text-forge-bg font-semibold rounded-lg transition-colors"
        >
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
          </svg>
          {program.demo_label || 'App öffnen'}
        </a>
      )}
      {/* Repository-Link fuer alle */}
      {program.github_url && (
        <a
          href={program.github_url}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 px-5 py-2.5 border border-forge-accent text-forge-accent hover:bg-forge-accent/10 font-semibold rounded-lg transition-colors"
        >
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
            <path d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0 1 12 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"/>
          </svg>
          Repository auf GitHub
        </a>
      )}
    </div>

    <!-- Academy CTA -->
    {program.academy_course_slug && (
      <div class="bg-academy-accent/10 border border-academy-accent/30 rounded-xl p-6 mb-8">
        <h3 class="font-bold text-academy-accent mb-2">Lern wie du das anpasst</h3>
        <p class="text-sm text-text-secondary mb-3">
          In der Asklaion Akademie lernst du, wie du dieses Programm an deine Bedürfnisse anpassen kannst.
        </p>
        <a
          href={`${base}academy/${program.academy_course_slug}`}
          class="inline-block px-4 py-2 bg-academy-accent hover:bg-academy-accent-light text-dark-base font-semibold rounded-lg transition-colors text-sm"
        >
          Zum Kurs &rarr;
        </a>
      </div>
    )}

    <!-- Anforderungen -->
    <div class="bg-dark-card border border-dark-border rounded-xl p-6 mb-8">
      <h3 class="font-bold text-text-primary mb-3">Anforderungen</h3>
      {program.anforderung === 'WEBAPP' ? (
        <p class="text-sm text-text-secondary">Keine Installation notwendig – läuft direkt im Browser. Ein aktueller Browser (Chrome, Firefox, Edge, Safari) reicht aus.</p>
      ) : program.anforderung === 'GERING' ? (
        <p class="text-sm text-text-secondary">Geringe Anforderungen – es wird keine besondere Hardware benötigt. Ein handelsüblicher Rechner mit etwas normalem Arbeitsspeicher (RAM) reicht vollkommen aus.</p>
      ) : program.anforderung === 'MITTEL' ? (
        <p class="text-sm text-text-secondary">Mittlere Anforderungen – ein Rechner mit mindestens einer Grafikkarte wird benötigt, um die lokalen KI-Modelle auszuführen. Eine integrierte oder einfache dedizierte GPU ist ausreichend.</p>
      ) : (
        <p class="text-sm text-text-secondary">Hohe Anforderungen – ein leistungsstarker Rechner mit mindestens einer guten dedizierten Grafikkarte (GPU) wird benötigt. Empfohlen wird eine NVIDIA-GPU mit mindestens 8 GB VRAM und CUDA-Support, um die KI-Modelle lokal performant auszuführen.</p>
      )}
      <a href={`${base}anforderungen`} class="inline-block mt-3 text-xs text-forge-accent hover:text-forge-accent-light transition-colors">Alle Anforderungsstufen im Detail &rarr;</a>
    </div>

    <!-- Lizenz -->
    <div class="bg-dark-card border border-dark-border rounded-xl p-6">
      <h3 class="font-bold text-text-primary mb-3">Lizenz & Haftungsausschluss</h3>
      <p class="text-sm text-text-secondary mb-3">
        Dieses Programm steht unter der <strong class="text-text-primary">MIT-Lizenz</strong> (Copyright 2026 Dr. Florian Rasche) und ist frei verfügbar.
      </p>
      <p class="text-xs text-text-muted leading-relaxed mb-2">
        Diese Software ist <strong>kein Medizinprodukt</strong> im Sinne der Verordnung (EU) 2017/745 (MDR) oder des Medizinprodukterecht-Durchführungsgesetzes (MPDG). Sie dient ausschließlich organisatorischen und administrativen Zwecken und ist nicht zur Diagnose, Prävention, Überwachung, Vorhersage, Prognose, Behandlung oder Linderung von Krankheiten bestimmt.
      </p>
      <p class="text-xs text-text-muted leading-relaxed">
        Es wird keinerlei Haftung übernommen. Jeder Nutzer ist für die eigene Anwendung selbst verantwortlich. Dies ergibt sich auch aus den Bedingungen der MIT-Lizenz, unter der die Software bereitgestellt wird.
      </p>
      <a href={`${base}lizenz`} class="inline-block mt-3 text-xs text-forge-accent hover:text-forge-accent-light transition-colors">Vollständige Lizenz & Haftungsausschluss &rarr;</a>
    </div>
  </div>
</BaseLayout>
