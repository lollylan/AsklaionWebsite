---
import '../styles/global.css';
const base = import.meta.env.BASE_URL;
---

<!DOCTYPE html>
<html lang="de">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content="Asklaion – Open-Source-Software für die Arztpraxis & Coding Akademie" />
  <title>Asklaion – Akademie & Projekte</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
  <link rel="icon" type="image/svg+xml" href={`${base}favicon.svg`} />
  <style>
    body {
      margin: 0;
      padding: 0;
      overflow: hidden;
      font-family: 'Inter', system-ui, sans-serif;
    }

    .gateway {
      display: flex;
      height: 100vh;
      width: 100vw;
    }

    .gateway-half {
      position: relative;
      flex: 1;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      transition: flex 400ms ease;
      overflow: hidden;
      cursor: pointer;
      text-decoration: none;
    }

    .gateway:hover .gateway-half {
      flex: 0.4;
    }

    .gateway:hover .gateway-half:hover {
      flex: 0.6;
    }

    .gateway-academy {
      background: linear-gradient(135deg, #1a1a1a 0%, #2d1f0f 50%, #1a1a1a 100%);
    }

    .gateway-forge {
      background: linear-gradient(135deg, #0f172a 0%, #0f2a2a 50%, #0f172a 100%);
    }

    .gateway-half::before {
      content: '';
      position: absolute;
      inset: 0;
      background-size: cover;
      background-position: center;
      opacity: 0.3;
      transition: opacity 400ms ease;
    }

    .gateway-half:hover::before {
      opacity: 0.5;
    }

    .gateway-academy::before {
      background-image: url('/AsklaionWebsite/images/academy-bg.webp');
      background-color: #1a1a1a;
    }

    .gateway-forge::before {
      background-image: url('/AsklaionWebsite/images/forge-bg.webp');
      background-color: #0f172a;
    }

    /* Noise overlay */
    .gateway-half::after {
      content: '';
      position: absolute;
      inset: 0;
      opacity: 0.04;
      background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
      pointer-events: none;
      z-index: 1;
    }

    .gateway-content {
      position: relative;
      z-index: 2;
      text-align: center;
      padding: 2rem;
    }

    .gateway-logo {
      font-size: 2.5rem;
      font-weight: 700;
      margin-bottom: 0.5rem;
      letter-spacing: -0.02em;
    }

    .gateway-academy .gateway-logo { color: #f59e0b; }
    .gateway-forge .gateway-logo { color: #14b8a6; }

    .gateway-tagline {
      font-size: 0.9rem;
      color: #94a3b8;
      margin-bottom: 2rem;
      max-width: 300px;
    }

    .gateway-cta {
      display: inline-block;
      padding: 0.75rem 2rem;
      border-radius: 0.5rem;
      font-weight: 600;
      font-size: 0.9rem;
      text-decoration: none;
      transition: all 300ms ease;
      font-family: 'Inter', system-ui, sans-serif;
    }

    .gateway-academy .gateway-cta {
      background: #f59e0b;
      color: #1a1a1a;
    }
    .gateway-academy .gateway-cta:hover {
      background: #fbbf24;
      box-shadow: 0 0 30px rgba(245, 158, 11, 0.4);
    }

    .gateway-forge .gateway-cta {
      background: #14b8a6;
      color: #0f172a;
    }
    .gateway-forge .gateway-cta:hover {
      background: #2dd4bf;
      box-shadow: 0 0 30px rgba(20, 184, 166, 0.4);
    }

    @media (max-width: 768px) {
      .gateway {
        flex-direction: column;
      }
      .gateway-half {
        height: 50vh;
        flex: none !important;
      }
      .gateway:hover .gateway-half,
      .gateway:hover .gateway-half:hover {
        flex: none !important;
      }
      .gateway-logo { font-size: 1.8rem; }
    }
  </style>
</head>
<body>
  <div class="gateway">
    <a href={`${base}forge`} class="gateway-half gateway-forge">
      <div class="gateway-content">
        <div class="gateway-logo">Asklaion Projekte</div>
        <p class="gateway-tagline">Open-Source-Programme für die Arztpraxis – kostenlos, lokal, datenschutzkonform</p>
        <span class="gateway-cta">Zu Projekte &rarr;</span>
      </div>
    </a>

    <a href={`${base}academy`} class="gateway-half gateway-academy">
      <div class="gateway-content">
        <div class="gateway-logo">Asklaion Akademie</div>
        <p class="gateway-tagline">Lerne Vibecoding und KI-Grundlagen – Schritt für Schritt zum eigenen Programm</p>
        <span class="gateway-cta">Zur Akademie &rarr;</span>
      </div>
    </a>
  </div>
</body>
</html>
