---
import BaseLayout from './BaseLayout.astro';

interface Props {
  title: string;
  courseTitle: string;
  courseSlug: string;
  lessonNumber: number;
  totalLessons: number;
  prevLesson?: { slug: string; title: string } | null;
  nextLesson?: { slug: string; title: string } | null;
  description?: string;
  videoUrl?: string;
}

const {
  title,
  courseTitle,
  courseSlug,
  lessonNumber,
  totalLessons,
  prevLesson = null,
  nextLesson = null,
  description = '',
  videoUrl = '',
} = Astro.props;

// Estimate reading time (~200 words per minute for German text)
const content = await Astro.slots.render('default');
const wordCount = content.replace(/<[^>]*>/g, '').split(/\s+/).length;
const readingTime = Math.max(1, Math.ceil(wordCount / 200));
---

<BaseLayout title={`${title} – ${courseTitle}`} description={description} variant="academy">
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <!-- Breadcrumb -->
    <nav class="mb-6 text-sm text-text-muted">
      <a href="/academy" class="hover:text-academy-accent transition-colors">Akademie</a>
      <span class="mx-2">/</span>
      <a href={`/academy/${courseSlug}`} class="hover:text-academy-accent transition-colors">{courseTitle}</a>
      <span class="mx-2">/</span>
      <span class="text-text-secondary">Lektion {lessonNumber}</span>
    </nav>

    <!-- Header -->
    <header class="mb-8">
      <div class="flex items-center gap-3 mb-2">
        <span class="px-2 py-0.5 text-xs font-medium rounded bg-academy-accent/20 text-academy-accent">
          Lektion {lessonNumber} von {totalLessons}
        </span>
        <span class="text-xs text-text-muted">{readingTime} Min. Lesezeit</span>
      </div>
      <h1 class="text-3xl font-bold text-text-primary">{title}</h1>
    </header>

    <!-- Progress bar -->
    <div class="mb-8">
      <div class="h-1 bg-dark-card rounded-full overflow-hidden">
        <div
          class="h-full bg-academy-accent rounded-full transition-all duration-500"
          style={`width: ${(lessonNumber / totalLessons) * 100}%`}
        />
      </div>
    </div>

    <!-- Video embed -->
    {videoUrl && (
      <div class="mb-8 aspect-video rounded-lg overflow-hidden bg-dark-card">
        <iframe
          src={videoUrl}
          class="w-full h-full"
          allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
          allowfullscreen
        />
      </div>
    )}

    <!-- Content -->
    <article class="prose prose-amber max-w-none
      [&_h1]:text-text-primary [&_h1]:font-bold
      [&_h2]:text-text-primary [&_h2]:font-semibold [&_h2]:mt-8 [&_h2]:mb-4
      [&_h3]:text-text-primary [&_h3]:font-medium [&_h3]:mt-5 [&_h3]:mb-2
      [&_p]:text-text-secondary [&_p]:leading-relaxed
      [&_a]:text-academy-accent [&_a]:no-underline hover:[&_a]:underline
      [&_strong]:text-text-primary
      [&_code]:px-1.5 [&_code]:py-0.5 [&_code]:rounded [&_code]:text-sm [&_code]:bg-[#1e293b] [&_code]:text-amber-300
      [&_pre]:bg-[#1e293b] [&_pre]:border [&_pre]:border-dark-border [&_pre]:rounded-lg [&_pre]:relative [&_pre]:text-slate-200
      [&_blockquote]:border-l-academy-accent [&_blockquote]:bg-dark-card/50 [&_blockquote]:rounded-r-lg [&_blockquote]:px-4 [&_blockquote]:py-3 [&_blockquote]:my-5
      [&_ul]:list-disc [&_ul]:pl-6 [&_ol]:list-decimal [&_ol]:pl-6 [&_li]:text-text-secondary [&_li]:mb-1
      [&_details]:my-5
      [&_table]:border-collapse [&_table]:w-full [&_table]:my-6 [&_th]:bg-dark-card [&_th]:px-4 [&_th]:py-2 [&_th]:text-left [&_th]:text-text-primary [&_td]:px-4 [&_td]:py-2 [&_td]:border-t [&_td]:border-dark-border [&_td]:text-text-secondary
    ">
      <slot />
    </article>

    <!-- Navigation -->
    <nav class="mt-10 pt-8 border-t border-dark-border flex justify-between items-center gap-4">
      {prevLesson ? (
        <a
          href={`/academy/${courseSlug}/${prevLesson.slug}`}
          class="group flex items-center gap-2 text-text-secondary hover:text-academy-accent transition-colors"
        >
          <svg class="w-5 h-5 group-hover:-translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
          </svg>
          <div class="text-right">
            <span class="text-xs text-text-muted block">Vorherige Lektion</span>
            <span class="text-sm font-medium">{prevLesson.title}</span>
          </div>
        </a>
      ) : <div />}

      {nextLesson ? (
        <a
          id="next-lesson-link"
          href={`/academy/${courseSlug}/${nextLesson.slug}`}
          data-course={courseSlug}
          data-lesson={lessonNumber}
          data-total={totalLessons}
          class="group flex items-center gap-3 px-5 py-3 bg-green-600/20 border border-green-600/40 hover:bg-green-600/30 rounded-lg transition-colors text-right"
        >
          <div>
            <span class="text-xs text-green-400 block">Lektion abschließen & weiter</span>
            <span class="text-sm font-medium text-text-primary">{nextLesson.title}</span>
          </div>
          <svg class="w-5 h-5 text-green-400 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
          </svg>
        </a>
      ) : (
        <a
          id="next-lesson-link"
          href={`/academy/${courseSlug}`}
          data-course={courseSlug}
          data-lesson={lessonNumber}
          data-total={totalLessons}
          class="group flex items-center gap-3 px-5 py-3 bg-green-600/20 border border-green-600/40 hover:bg-green-600/30 rounded-lg transition-colors text-right"
        >
          <div>
            <span class="text-xs text-green-400 block">Kurs abschließen</span>
            <span class="text-sm font-medium text-text-primary">Zurück zur Kursübersicht</span>
          </div>
          <svg class="w-5 h-5 text-green-400 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
          </svg>
        </a>
      )}
    </nav>
  </div>

  <script>
    // Add copy buttons to all code blocks
    document.querySelectorAll('article pre').forEach((pre) => {
      const wrapper = document.createElement('div');
      wrapper.className = 'relative group';
      pre.parentNode!.insertBefore(wrapper, pre);
      wrapper.appendChild(pre);

      const btn = document.createElement('button');
      btn.className = 'absolute top-2 right-2 px-2 py-1 text-xs rounded bg-dark-border/80 text-text-muted hover:text-text-primary hover:bg-dark-border opacity-0 group-hover:opacity-100 transition-all duration-200 font-sans';
      btn.textContent = 'Kopieren';
      btn.addEventListener('click', () => {
        const code = pre.querySelector('code');
        const text = (code || pre).textContent || '';
        navigator.clipboard.writeText(text).then(() => {
          btn.textContent = 'Kopiert!';
          btn.classList.add('text-academy-accent');
          setTimeout(() => {
            btn.textContent = 'Kopieren';
            btn.classList.remove('text-academy-accent');
          }, 2000);
        });
      });
      wrapper.appendChild(btn);
    });
  </script>

  <script>
    const nextLink = document.getElementById('next-lesson-link');
    if (nextLink) {
      const course = nextLink.dataset.course!;
      const lesson = parseInt(nextLink.dataset.lesson!, 10);
      const total = parseInt(nextLink.dataset.total!, 10);

      nextLink.addEventListener('click', () => {
        localStorage.setItem(`academy_${course}_lesson_${lesson}`, 'completed');

        // Check if all lessons in the course are done
        let allDone = true;
        for (let i = 1; i <= total; i++) {
          if (localStorage.getItem(`academy_${course}_lesson_${i}`) !== 'completed') {
            allDone = false;
            break;
          }
        }
        if (allDone) {
          localStorage.setItem(`academy_course_${course}`, 'completed');
        }
      });
    }
  </script>
</BaseLayout>
