---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  showNav?: boolean;
  variant?: 'default' | 'forge' | 'academy';
}

const { title, description = 'Asklaion – Open-Source-Software für die Arztpraxis & Coding Akademie', showNav = true, variant = 'default' } = Astro.props;
---

<!DOCTYPE html>
<html lang="de" class="dark">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <title>{title} | Asklaion</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <!-- Prevent flash: apply theme before render -->
  <script is:inline>
    (function() {
      const t = localStorage.getItem('theme');
      if (t === 'light') document.documentElement.classList.replace('dark', 'light');
    })();
  </script>
</head>
<body class="min-h-screen flex flex-col relative bg-light-base dark:bg-dark-base text-light-text-primary dark:text-text-primary transition-colors duration-300">
  {/* Background ambience – dark mode */}
  {variant === 'forge' && (
    <div class="fixed inset-0 -z-10 pointer-events-none dark:block hidden" aria-hidden="true">
      <div class="absolute inset-0 bg-gradient-to-br from-[#0f172a] via-[#0a0a0a] to-[#0a0a0a]" />
      <div class="absolute top-0 left-0 w-[80%] h-[70%] bg-[radial-gradient(ellipse_at_top_left,rgba(20,184,166,0.25)_0%,transparent_60%)]" />
      <div class="absolute bottom-0 right-0 w-[60%] h-[50%] bg-[radial-gradient(ellipse_at_bottom_right,rgba(20,184,166,0.15)_0%,transparent_60%)]" />
    </div>
  )}
  {variant === 'academy' && (
    <div class="fixed inset-0 -z-10 pointer-events-none dark:block hidden" aria-hidden="true">
      <div class="absolute inset-0 bg-gradient-to-br from-[#1a1a1a] via-[#0a0a0a] to-[#0a0a0a]" />
      <div class="absolute top-0 right-0 w-[80%] h-[70%] bg-[radial-gradient(ellipse_at_top_right,rgba(245,158,11,0.25)_0%,transparent_60%)]" />
      <div class="absolute bottom-0 left-0 w-[60%] h-[50%] bg-[radial-gradient(ellipse_at_bottom_left,rgba(245,158,11,0.15)_0%,transparent_60%)]" />
    </div>
  )}
  {/* Background ambience – light mode */}
  {variant === 'forge' && (
    <div class="fixed inset-0 -z-10 pointer-events-none dark:hidden block" aria-hidden="true">
      <div class="absolute inset-0 bg-gradient-to-br from-[#f0fdfa] via-[#f8fafc] to-[#f8fafc]" />
      <div class="absolute top-0 left-0 w-[80%] h-[70%] bg-[radial-gradient(ellipse_at_top_left,rgba(20,184,166,0.12)_0%,transparent_60%)]" />
      <div class="absolute bottom-0 right-0 w-[60%] h-[50%] bg-[radial-gradient(ellipse_at_bottom_right,rgba(20,184,166,0.08)_0%,transparent_60%)]" />
    </div>
  )}
  {variant === 'academy' && (
    <div class="fixed inset-0 -z-10 pointer-events-none dark:hidden block" aria-hidden="true">
      <div class="absolute inset-0 bg-gradient-to-br from-[#fffbeb] via-[#f8fafc] to-[#f8fafc]" />
      <div class="absolute top-0 right-0 w-[80%] h-[70%] bg-[radial-gradient(ellipse_at_top_right,rgba(245,158,11,0.12)_0%,transparent_60%)]" />
      <div class="absolute bottom-0 left-0 w-[60%] h-[50%] bg-[radial-gradient(ellipse_at_bottom_left,rgba(245,158,11,0.08)_0%,transparent_60%)]" />
    </div>
  )}

  {showNav && (
    <nav class="fixed top-0 left-0 right-0 z-50 bg-light-base/90 dark:bg-dark-base/90 backdrop-blur-md border-b border-light-border dark:border-dark-border transition-colors duration-300">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex items-center justify-between h-16">
          <a href="/" class="flex items-center gap-2 text-light-text-primary dark:text-text-primary hover:text-academy-accent transition-colors">
            <span class="font-bold text-lg">Asklaion</span>
          </a>

          <div class="hidden md:flex items-center gap-8">
            <a href="/academy" class="text-light-text-secondary dark:text-text-secondary hover:text-academy-accent transition-colors text-sm font-medium">Akademie</a>
            <a href="/forge" class="text-light-text-secondary dark:text-text-secondary hover:text-forge-accent transition-colors text-sm font-medium">Projekte</a>
            <a href="https://github.com/lollylan" target="_blank" rel="noopener noreferrer" class="text-light-text-secondary dark:text-text-secondary hover:text-light-text-primary dark:hover:text-text-primary transition-colors text-sm font-medium">GitHub</a>

            <!-- Theme toggle -->
            <button
              id="theme-toggle"
              class="p-2 rounded-lg text-light-text-secondary dark:text-text-secondary hover:text-light-text-primary dark:hover:text-text-primary hover:bg-light-card dark:hover:bg-dark-card transition-colors"
              aria-label="Darstellung wechseln"
            >
              <!-- Sun icon (visible in dark mode) -->
              <svg class="w-5 h-5 hidden dark:block" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z" />
              </svg>
              <!-- Moon icon (visible in light mode) -->
              <svg class="w-5 h-5 block dark:hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z" />
              </svg>
            </button>
          </div>

          <div class="flex items-center gap-2 md:hidden">
            <!-- Mobile theme toggle -->
            <button
              id="theme-toggle-mobile"
              class="p-2 text-light-text-secondary dark:text-text-secondary hover:text-light-text-primary dark:hover:text-text-primary"
              aria-label="Darstellung wechseln"
            >
              <svg class="w-5 h-5 hidden dark:block" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z" />
              </svg>
              <svg class="w-5 h-5 block dark:hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z" />
              </svg>
            </button>

            <button
              id="mobile-menu-btn"
              class="text-light-text-secondary dark:text-text-secondary hover:text-light-text-primary dark:hover:text-text-primary p-2"
              aria-label="Menü öffnen"
            >
              <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
              </svg>
            </button>
          </div>
        </div>
      </div>

      <div id="mobile-menu" class="hidden md:hidden border-t border-light-border dark:border-dark-border bg-light-base/95 dark:bg-dark-base/95 backdrop-blur-md">
        <div class="px-4 py-4 space-y-3">
          <a href="/academy" class="block text-light-text-secondary dark:text-text-secondary hover:text-academy-accent transition-colors text-sm font-medium">Akademie</a>
          <a href="/forge" class="block text-light-text-secondary dark:text-text-secondary hover:text-forge-accent transition-colors text-sm font-medium">Projekte</a>
          <a href="https://github.com/lollylan" target="_blank" rel="noopener noreferrer" class="block text-light-text-secondary dark:text-text-secondary hover:text-light-text-primary dark:hover:text-text-primary transition-colors text-sm font-medium">GitHub</a>
        </div>
      </div>
    </nav>
  )}

  <main class={showNav ? 'pt-16 flex-1' : 'flex-1'}>
    <slot />
  </main>

  {showNav && (
    <footer class="border-t border-light-border dark:border-dark-border bg-light-base/80 dark:bg-dark-base/80 backdrop-blur-md transition-colors duration-300">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
        <div class="flex flex-col md:flex-row justify-between items-center gap-4">
          <div class="flex items-center gap-6 text-sm text-light-text-muted dark:text-text-muted">
            <a href="/impressum" class="hover:text-light-text-secondary dark:hover:text-text-secondary transition-colors">Impressum</a>
            <a href="/anforderungen" class="hover:text-light-text-secondary dark:hover:text-text-secondary transition-colors">Anforderungen</a>
            <a href="/lizenz" class="hover:text-light-text-secondary dark:hover:text-text-secondary transition-colors">Lizenz</a>
            <a href="https://github.com/lollylan" target="_blank" rel="noopener noreferrer" class="hover:text-light-text-secondary dark:hover:text-text-secondary transition-colors">GitHub</a>
          </div>
          <p class="text-sm text-light-text-muted dark:text-text-muted">&copy; 2026 Dr. Florian Rasche &middot; Asklaion &middot; MIT Lizenz</p>
        </div>
        <p class="text-center text-xs text-light-text-muted dark:text-text-muted mt-4">Open Source &middot; MIT Lizenz &middot; 100 % lokal</p>
      </div>
    </footer>
  )}

  <script>
    function toggleTheme() {
      const html = document.documentElement;
      const isDark = html.classList.contains('dark');
      html.classList.replace(isDark ? 'dark' : 'light', isDark ? 'light' : 'dark');
      localStorage.setItem('theme', isDark ? 'light' : 'dark');
    }

    document.getElementById('theme-toggle')?.addEventListener('click', toggleTheme);
    document.getElementById('theme-toggle-mobile')?.addEventListener('click', toggleTheme);

    document.getElementById('mobile-menu-btn')?.addEventListener('click', () => {
      document.getElementById('mobile-menu')?.classList.toggle('hidden');
    });
  </script>
</body>
</html>
